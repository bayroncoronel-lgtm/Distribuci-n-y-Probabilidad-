      "source": [
        "# Generar puntos para la distribución normal estándar\n",
        "x = np.linspace(-4, 4, 1000)\n",
        "y = norm.pdf(x)\n",
        "\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.plot(x, y, color='blue', lw=2, label='Distribución Normal Estándar')\n",
        "\n",
        "# Marcar el estadístico Z calculado\n",
        "plt.axvline(Z_calc, color='red', linestyle='--', label=f'Z Calculado: {Z_calc:.2f}')\n",
        "\n",
        "# Calcular los valores críticos para una prueba de dos colas\n",
        "Z_critical_upper = norm.ppf(1 - alpha/2)\n",
        "Z_critical_lower = norm.ppf(alpha/2)\n",
        "\n",
        "# Marcar los valores críticos\n",
        "plt.axvline(Z_critical_upper, color='green', linestyle=':', label=f'Z Crítico (alpha/2): {Z_critical_upper:.2f}')\n",
        "plt.axvline(Z_critical_lower, color='green', linestyle=':')\n",
        "\n",
        "# Sombrear la región de rechazo (cola superior)\n",
        "x_reject_upper = x[x > Z_critical_upper]\n",
        "y_reject_upper = norm.pdf(x_reject_upper)\n",
        "plt.fill_between(x_reject_upper, 0, y_reject_upper, color='green', alpha=0.3, label=r'Región de Rechazo ($\\alpha/2$)')\n",
        "\n",
        "# Sombrear la región de rechazo (cola inferior)\n",
        "x_reject_lower = x[x < Z_critical_lower]\n",
        "y_reject_lower = norm.pdf(x_reject_lower)\n",
        "plt.fill_between(x_reject_lower, 0, y_reject_lower, color='green', alpha=0.3)\n",
        "\n",
        "# Sombrear el valor-p (solo si el Z_calc está en la región de rechazo, para claridad)\n",
        "# Si Z_calc es positivo, sombrear desde Z_calc hacia la derecha y desde -Z_calc hacia la izquierda\n",
        "# Si Z_calc es negativo, sombrear desde Z_calc hacia la izquierda y desde -Z_calc hacia la derecha\n",
        "\n",
        "if np.abs(Z_calc) > Z_critical_upper: # Si cae en la región de rechazo\n",
        "    x_p_value_upper = x[x > np.abs(Z_calc)]\n",
        "    y_p_value_upper = norm.pdf(x_p_value_upper)\n",
        "    plt.fill_between(x_p_value_upper, 0, y_p_value_upper, color='orange', alpha=0.5, label='Valor-p (Área)')\n",
        "\n",
        "    x_p_value_lower = x[x < -np.abs(Z_calc)]\n",
        "    y_p_value_lower = norm.pdf(x_p_value_lower)\n",
        "    plt.fill_between(x_p_value_lower, 0, y_p_value_lower, color='orange', alpha=0.5)\n",
        "\n",
        "plt.title('Prueba de Hipótesis Z (Dos Colas)')\n",
        "plt.xlabel('Estadístico Z')\n",
        "plt.ylabel('Densidad de Probabilidad')\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "plt.show()"
